---
import Base from "../../layouts/Base.astro";
import {
	fetchListing,
	formatJpy,
	statusLabel,
	prefectureLabel,
	type KuraEnv,
} from "../../lib/kura";

const env = Astro.locals.runtime?.env as KuraEnv | undefined;
const { slug } = Astro.params;
const listing = await fetchListing(env ?? {}, slug ?? "");
if (!listing) return new Response("Not found", { status: 404 });

const photos = [listing.hero_image, listing.photo_2, listing.photo_3].filter(
	(x): x is string => typeof x === "string" && x.length > 0,
);
const hasGeo = listing.latitude != null && listing.longitude != null;
---

<Base
	title={`${listing.title} - Inaka`}
	description={listing.description ?? `${listing.title} - ${listing.location}`}
>
	<article>
		<nav class="crumb">
			<a href="/">Inaka</a> ›
			<a href={`/?prefecture=${listing.prefecture}`}>{prefectureLabel(listing.prefecture)}</a> ›
			<span>{listing.location.split(",")[0]}</span>
		</nav>

		<header class="hdr">
			<div>
				<span class={`status status-${listing.status}`}>{statusLabel(listing.status)}</span>
				<h1>{listing.title}</h1>
				<p class="loc">{listing.location}</p>
			</div>
			<p class="price">{formatJpy(listing.price_jpy)}</p>
		</header>

		{photos.length > 0 && (
			<section class={`gallery gallery-${photos.length}`}>
				<a class="g-main" href={photos[0]} target="_blank" rel="noreferrer">
					<img src={photos[0]} alt={listing.title} />
				</a>
				{photos.slice(1).map((p) => (
					<a class="g-thumb" href={p} target="_blank" rel="noreferrer">
						<img src={p} alt={listing.title} loading="lazy" />
					</a>
				))}
			</section>
		)}

		<dl class="facts">
			{listing.layout && <div><dt>Layout</dt><dd>{listing.layout}</dd></div>}
			{listing.square_meters != null && <div><dt>Floor area</dt><dd>{listing.square_meters} m²</dd></div>}
			{listing.land_area_sqm != null && <div><dt>Land area</dt><dd>{listing.land_area_sqm.toLocaleString()} m²</dd></div>}
			{listing.bedrooms != null && <div><dt>Bedrooms</dt><dd>{listing.bedrooms}</dd></div>}
			{listing.build_year != null && <div><dt>Built</dt><dd>{listing.build_year}</dd></div>}
		</dl>

		{listing.description && (
			<section class="body">
				<p>{listing.description}</p>
			</section>
		)}

		{hasGeo && (
			<section class="map-block">
				<h2>Location</h2>
				<div
					id="mini-map"
					data-lat={listing.latitude}
					data-lon={listing.longitude}
					data-title={listing.title}
				></div>
				<p class="mini-map-meta">
					<a href={`/map?focus=${listing.slug}`}>See on the full map ›</a>
				</p>
			</section>
		)}
	</article>
</Base>

<script>
	import maplibregl from "maplibre-gl";
	const el = document.getElementById("mini-map") as HTMLDivElement | null;
	if (el) {
		const lat = parseFloat(el.dataset.lat ?? "0");
		const lon = parseFloat(el.dataset.lon ?? "0");
		const map = new maplibregl.Map({
			container: el,
			style: "https://tiles.openfreemap.org/styles/liberty",
			center: [lon, lat],
			zoom: 9,
			attributionControl: { compact: true },
		});
		map.on("load", () => {
			new maplibregl.Marker({ color: "#2f4737" }).setLngLat([lon, lat]).addTo(map);
		});
	}
</script>

<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4/dist/maplibre-gl.css" />

<style>
	article {
		padding: 1rem 0 4rem;
	}
	.crumb {
		font-size: 0.85rem;
		color: var(--muted);
		margin: 0 0 1.5rem;
	}
	.crumb a {
		color: var(--muted);
		text-decoration: none;
	}
	.crumb a:hover {
		color: var(--fg);
	}
	.crumb span {
		color: var(--fg);
	}
	.hdr {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 2rem;
		flex-wrap: wrap;
		margin-bottom: 2rem;
	}
	.hdr .status {
		display: inline-block;
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.2rem 0.55rem;
		border-radius: 4px;
		background: var(--badge-available);
		color: #fff;
		font-weight: 600;
		margin-bottom: 0.85rem;
	}
	.status-under_offer {
		background: var(--badge-under-offer);
	}
	.status-sold {
		background: var(--badge-sold);
	}
	h1 {
		font-size: clamp(2rem, 4.5vw, 2.8rem);
		margin: 0 0 0.5rem;
		line-height: 1.1;
		max-width: 32rem;
	}
	.loc {
		color: var(--muted);
		margin: 0;
		font-size: 0.95rem;
	}
	.price {
		font-size: clamp(1.5rem, 3.5vw, 2rem);
		font-weight: 700;
		color: var(--accent);
		margin: 0;
		white-space: nowrap;
	}
	.gallery {
		display: grid;
		grid-template-columns: 2fr 1fr;
		grid-template-rows: repeat(2, 1fr);
		gap: 0.5rem;
		aspect-ratio: 16 / 9;
		margin-bottom: 2.5rem;
		border-radius: 14px;
		overflow: hidden;
	}
	.gallery.gallery-1 {
		grid-template-columns: 1fr;
		grid-template-rows: 1fr;
		aspect-ratio: 16 / 10;
	}
	.gallery.gallery-2 {
		grid-template-rows: 1fr;
	}
	.g-main,
	.g-thumb {
		display: block;
		overflow: hidden;
		background: var(--accent-soft);
	}
	.g-main {
		grid-row: 1 / 3;
	}
	.gallery.gallery-2 .g-main {
		grid-row: auto;
	}
	.gallery.gallery-1 .g-main {
		grid-row: auto;
	}
	.g-main img,
	.g-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.4s ease;
	}
	.g-main:hover img,
	.g-thumb:hover img {
		transform: scale(1.02);
	}
	.facts {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(7rem, 1fr));
		gap: 1.25rem 1rem;
		padding: 1.5rem 0;
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		margin: 0 0 2.5rem;
	}
	dt {
		color: var(--faint);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin: 0 0 0.25rem;
	}
	dd {
		margin: 0;
		font-size: 1.15rem;
		font-weight: 500;
	}
	.body p {
		line-height: 1.75;
		font-size: 1.05rem;
		max-width: 42rem;
		margin: 0 0 3rem;
	}
	.map-block h2 {
		font-size: 1.1rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
		margin: 0 0 1rem;
	}
	#mini-map {
		height: 300px;
		border-radius: 10px;
		border: 1px solid var(--line);
		overflow: hidden;
	}
	.mini-map-meta {
		margin: 0.85rem 0 0;
		font-size: 0.9rem;
	}
	.mini-map-meta a {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	@media (max-width: 600px) {
		.gallery {
			grid-template-columns: 1fr;
			grid-template-rows: auto;
			aspect-ratio: auto;
		}
		.g-main,
		.g-thumb {
			aspect-ratio: 4 / 3;
		}
		.g-main {
			grid-row: auto;
		}
	}
</style>
