---
import Base from "../../layouts/Base.astro";
import {
	fetchListing,
	formatJpy,
	statusLabel,
	prefectureLabel,
	readDemoOverride,
	isDeadProjectError,
	type KuraEnv,
	type DemoOverride,
} from "../../lib/kura";

const env = Astro.locals.runtime?.env as KuraEnv | undefined;
const { slug } = Astro.params;
const cookieHeader = Astro.request.headers.get("cookie") ?? undefined;
let override: DemoOverride | undefined = readDemoOverride(Astro.url, cookieHeader);
Astro.response.headers.set("Cache-Control", "no-cache, must-revalidate");

let listing = null;
try {
	listing = await fetchListing(env ?? {}, slug ?? "", override);
} catch (e) {
	if (override?.source === "cookie" && isDeadProjectError(e)) {
		Astro.cookies.delete("kura_demo_preview", { path: "/" });
		override = undefined;
		listing = await fetchListing(env ?? {}, slug ?? "", undefined);
	} else {
		throw e;
	}
}
if (!listing) return new Response("Not found", { status: 404 });

const photos = [listing.hero_image, listing.photo_2, listing.photo_3].filter(
	(x): x is string => typeof x === "string" && x.length > 0,
);
const hasGeo = listing.latitude != null && listing.longitude != null;
---

<Base
	title={`${listing.title} - Inaka`}
	description={listing.description ?? `${listing.title} - ${listing.location}`}
>
	<article>
		<nav class="crumb">
			<a href="/">Inaka</a> ›
			<a href={`/?prefecture=${listing.prefecture_slug}`}>{prefectureLabel(listing.prefecture_slug)}</a> ›
			<span>{listing.location.split(",")[0]}</span>
		</nav>

		<header class="hdr">
			<div>
				<span class={`status status-${listing.status}`}>{statusLabel(listing.status)}</span>
				<h1>{listing.title}</h1>
				<p class="loc">{listing.location}</p>
			</div>
			<p class="price">{formatJpy(listing.price_jpy)}</p>
		</header>

		{photos.length > 0 && (
			<section class={`gallery gallery-${photos.length}`} data-lightbox-gallery>
				<button class="g-main" type="button" data-photo={photos[0]} data-index="0">
					<img src={photos[0]} alt={listing.title} />
				</button>
				{photos.slice(1).map((p, i) => (
					<button class="g-thumb" type="button" data-photo={p} data-index={String(i + 1)}>
						<img src={p} alt={listing.title} loading="lazy" />
					</button>
				))}
			</section>
		)}

		<div id="lightbox" hidden aria-hidden="true" role="dialog">
			<button class="lb-close" type="button" aria-label="Close">×</button>
			<button class="lb-prev" type="button" aria-label="Previous">‹</button>
			<img id="lb-image" alt="" />
			<button class="lb-next" type="button" aria-label="Next">›</button>
		</div>

		<dl class="facts">
			{listing.layout && <div><dt>Layout</dt><dd>{listing.layout}</dd></div>}
			{listing.square_meters != null && <div><dt>Floor area</dt><dd>{listing.square_meters} m²</dd></div>}
			{listing.land_area_sqm != null && <div><dt>Land area</dt><dd>{listing.land_area_sqm.toLocaleString()} m²</dd></div>}
			{listing.bedrooms != null && <div><dt>Bedrooms</dt><dd>{listing.bedrooms}</dd></div>}
			{listing.build_year != null && <div><dt>Built</dt><dd>{listing.build_year}</dd></div>}
		</dl>

		{(listing.description || listing.floor_plan) && (
			<section class="body">
				<div class="body-text">
					{listing.description && <p>{listing.description}</p>}
				</div>
				{listing.floor_plan && (
					<aside class="floor-plan" data-lightbox-gallery-plan>
						<p class="floor-plan-label">Floor plan</p>
						<button class="fp-btn" type="button" data-photo={listing.floor_plan}>
							<img src={listing.floor_plan} alt={`Floor plan - ${listing.title}`} loading="lazy" />
						</button>
					</aside>
				)}
			</section>
		)}

		{hasGeo && (
			<section class="map-block">
				<h2>Location</h2>
				<div
					id="mini-map"
					data-lat={listing.latitude}
					data-lon={listing.longitude}
					data-title={listing.title}
				></div>
				<p class="mini-map-meta">
					<a href={`/map?focus=${listing.slug}`}>See on the full map ›</a>
				</p>
			</section>
		)}
	</article>
</Base>

<script>
	const galleryBtns = Array.from(
		document.querySelectorAll<HTMLButtonElement>("[data-lightbox-gallery] button"),
	);
	const planBtn = document.querySelector<HTMLButtonElement>(".fp-btn");
	const photos = galleryBtns.map((b) => b.dataset.photo ?? "");
	if (planBtn?.dataset.photo) photos.push(planBtn.dataset.photo);
	const lb = document.getElementById("lightbox") as HTMLDivElement | null;
	const lbImg = document.getElementById("lb-image") as HTMLImageElement | null;
	let lbIndex = 0;

	function showLightbox(i: number) {
		if (!lb || !lbImg || photos.length === 0) return;
		lbIndex = (i + photos.length) % photos.length;
		lbImg.src = photos[lbIndex];
		lb.hidden = false;
		lb.setAttribute("aria-hidden", "false");
		document.body.style.overflow = "hidden";
	}
	function hideLightbox() {
		if (!lb) return;
		lb.hidden = true;
		lb.setAttribute("aria-hidden", "true");
		document.body.style.overflow = "";
	}
	galleryBtns.forEach((btn) => {
		btn.addEventListener("click", () => showLightbox(Number(btn.dataset.index ?? 0)));
	});
	planBtn?.addEventListener("click", () => showLightbox(photos.length - 1));
	lb?.querySelector(".lb-close")?.addEventListener("click", hideLightbox);
	lb?.querySelector(".lb-prev")?.addEventListener("click", (e) => {
		e.stopPropagation();
		showLightbox(lbIndex - 1);
	});
	lb?.querySelector(".lb-next")?.addEventListener("click", (e) => {
		e.stopPropagation();
		showLightbox(lbIndex + 1);
	});
	lb?.addEventListener("click", (e) => {
		if (e.target === lb) hideLightbox();
	});
	document.addEventListener("keydown", (e) => {
		if (lb?.hidden) return;
		if (e.key === "Escape") hideLightbox();
		else if (e.key === "ArrowLeft") showLightbox(lbIndex - 1);
		else if (e.key === "ArrowRight") showLightbox(lbIndex + 1);
	});

	import maplibregl from "maplibre-gl";
	const el = document.getElementById("mini-map") as HTMLDivElement | null;
	if (el) {
		const lat = parseFloat(el.dataset.lat ?? "0");
		const lon = parseFloat(el.dataset.lon ?? "0");
		const map = new maplibregl.Map({
			container: el,
			style: "https://tiles.openfreemap.org/styles/liberty",
			center: [lon, lat],
			zoom: 9,
			attributionControl: { compact: true },
		});
		map.on("load", () => {
			new maplibregl.Marker({ color: "#c45a3a" }).setLngLat([lon, lat]).addTo(map);
		});
	}
</script>

<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4/dist/maplibre-gl.css" />

<style>
	article {
		padding: 2.5rem 0 4rem;
	}
	.crumb {
		font-family: var(--sans);
		font-size: 0.7rem;
		color: var(--slate);
		margin: 0 0 2.5rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
	}
	.crumb a {
		color: var(--slate);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		padding-bottom: 1px;
	}
	.crumb a:hover {
		color: var(--ink);
		border-bottom-color: var(--accent);
	}
	.crumb span {
		color: var(--ink);
	}
	.hdr {
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: end;
		gap: 2rem;
		padding-bottom: 1.6rem;
		border-bottom: 1px solid var(--rule);
		margin-bottom: 2.5rem;
	}
	.hdr .status {
		display: inline-block;
		font-family: var(--sans);
		font-size: 0.62rem;
		text-transform: uppercase;
		letter-spacing: 0.22em;
		padding: 0.32rem 0.7rem;
		background: var(--ink);
		color: var(--paper);
		font-weight: 500;
		margin-bottom: 1.1rem;
	}
	.status-under_offer {
		background: var(--accent);
	}
	.status-sold {
		background: var(--slate-soft);
		color: var(--ink);
	}
	h1 {
		font-family: var(--serif);
		font-size: clamp(2.3rem, 5vw, 3.4rem);
		margin: 0 0 0.7rem;
		line-height: 1.05;
		letter-spacing: -0.008em;
		font-weight: 500;
		max-width: 36rem;
	}
	.loc {
		font-family: var(--sans);
		color: var(--slate);
		margin: 0;
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-weight: 500;
	}
	.price {
		font-family: var(--sans);
		font-size: clamp(1.3rem, 2.6vw, 1.7rem);
		font-weight: 500;
		background: var(--accent);
		color: var(--paper);
		margin: 0;
		padding: 0.65rem 1rem;
		white-space: nowrap;
		letter-spacing: 0.02em;
		align-self: end;
	}
	@media (max-width: 640px) {
		.hdr {
			grid-template-columns: 1fr;
			align-items: start;
		}
		.price {
			justify-self: start;
		}
	}
	.gallery {
		display: grid;
		grid-template-columns: 2fr 1fr;
		grid-template-rows: repeat(2, 1fr);
		gap: 0.4rem;
		aspect-ratio: 16 / 9;
		margin-bottom: 3rem;
		border-radius: 0;
		overflow: hidden;
	}
	.gallery.gallery-1 {
		grid-template-columns: 1fr;
		grid-template-rows: 1fr;
		aspect-ratio: 16 / 10;
	}
	.gallery.gallery-2 {
		grid-template-rows: 1fr;
	}
	.g-main,
	.g-thumb {
		display: block;
		overflow: hidden;
		background: var(--accent-soft);
		border: 0;
		padding: 0;
		cursor: zoom-in;
		font: inherit;
		color: inherit;
		position: relative;
	}
	.g-main:focus-visible,
	.g-thumb:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
	.g-main {
		grid-row: 1 / 3;
	}
	.gallery.gallery-2 .g-main {
		grid-row: auto;
	}
	.gallery.gallery-1 .g-main {
		grid-row: auto;
	}
	.g-main img,
	.g-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.4s ease;
	}
	.g-main:hover img,
	.g-thumb:hover img {
		transform: scale(1.02);
	}
	.facts {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(7rem, 1fr));
		gap: 1.5rem 1rem;
		padding: 1.75rem 0;
		border-top: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule);
		margin: 0 0 3rem;
		font-family: var(--sans);
	}
	dt {
		color: var(--slate-soft);
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.22em;
		margin: 0 0 0.4rem;
		font-weight: 500;
	}
	dd {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 400;
		color: var(--ink);
		font-family: var(--serif);
	}
	.body {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 3rem;
		align-items: start;
		margin: 0 0 3rem;
	}
	.body-text {
		max-width: 42rem;
	}
	.body-text p {
		line-height: 1.8;
		font-size: 1.05rem;
		margin: 0;
		font-family: var(--sans);
		color: var(--ink-2);
	}
	.floor-plan {
		width: 18rem;
		flex-shrink: 0;
	}
	.floor-plan-label {
		font-family: var(--sans);
		font-size: 0.62rem;
		text-transform: uppercase;
		letter-spacing: 0.22em;
		color: var(--slate);
		margin: 0 0 0.65rem;
		font-weight: 500;
	}
	.fp-btn {
		display: block;
		width: 100%;
		padding: 0.6rem;
		border: 1px solid var(--rule);
		border-radius: 0;
		background: var(--card);
		cursor: zoom-in;
		font: inherit;
		color: inherit;
		transition:
			border-color 0.15s,
			box-shadow 0.15s;
	}
	.fp-btn:hover,
	.fp-btn:focus-visible {
		border-color: var(--accent);
		box-shadow: 0 4px 14px rgba(0, 0, 0, 0.06);
		outline: none;
	}
	.fp-btn img {
		display: block;
		width: 100%;
		height: auto;
		max-height: 18rem;
		object-fit: contain;
	}
	@media (max-width: 760px) {
		.body {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.floor-plan {
			width: 100%;
			max-width: 22rem;
		}
	}
	.map-block h2 {
		font-family: var(--sans);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.22em;
		color: var(--slate);
		font-weight: 500;
		margin: 0 0 1.1rem;
	}
	#mini-map {
		height: 320px;
		border-radius: 0;
		border: 1px solid var(--rule);
		overflow: hidden;
	}
	.mini-map-meta {
		margin: 1rem 0 0;
		font-family: var(--sans);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.18em;
	}
	.mini-map-meta a {
		color: var(--ink);
		text-decoration: none;
		border-bottom: 1px solid var(--accent);
		padding-bottom: 2px;
	}
	.mini-map-meta a:hover {
		color: var(--accent-deep);
	}
	#lightbox {
		position: fixed;
		inset: 0;
		background: rgba(20, 18, 14, 0.92);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 1000;
		padding: clamp(1rem, 4vw, 3rem);
	}
	#lightbox[hidden] {
		display: none;
	}
	#lb-image {
		max-width: 100%;
		max-height: 100%;
		object-fit: contain;
		display: block;
		border-radius: 4px;
		box-shadow: 0 10px 60px rgba(0, 0, 0, 0.4);
	}
	#lightbox button {
		background: rgba(0, 0, 0, 0.45);
		color: #fff;
		border: 0;
		font-size: 1.5rem;
		line-height: 1;
		width: 2.6rem;
		height: 2.6rem;
		border-radius: 50%;
		cursor: pointer;
		position: absolute;
		font-family: ui-sans-serif, system-ui, sans-serif;
		transition: background 0.15s;
	}
	#lightbox button:hover,
	#lightbox button:focus-visible {
		background: rgba(0, 0, 0, 0.75);
		outline: none;
	}
	#lightbox .lb-close {
		top: 1.25rem;
		right: 1.25rem;
		font-size: 1.6rem;
	}
	#lightbox .lb-prev {
		left: 1.25rem;
		top: 50%;
		transform: translateY(-50%);
	}
	#lightbox .lb-next {
		right: 1.25rem;
		top: 50%;
		transform: translateY(-50%);
	}
	@media (max-width: 600px) {
		.gallery {
			grid-template-columns: 1fr;
			grid-template-rows: auto;
			aspect-ratio: auto;
		}
		.g-main,
		.g-thumb {
			aspect-ratio: 4 / 3;
		}
		.g-main {
			grid-row: auto;
		}
	}
</style>
