---
import Base from "../layouts/Base.astro";
import { marked } from "marked";
import {
	fetchPage,
	readDemoOverride,
	type KuraEnv,
	type DemoOverride,
} from "../lib/kura";

const env = Astro.locals.runtime?.env as KuraEnv | undefined;
const cookieHeader = Astro.request.headers.get("cookie") ?? undefined;
const override: DemoOverride | undefined = readDemoOverride(Astro.url, cookieHeader);

Astro.response.headers.set("Cache-Control", "no-cache, must-revalidate");

let page = null;
let loadError: string | null = null;
try {
	page = await fetchPage(env ?? {}, "terms", override);
} catch (e) {
	loadError = e instanceof Error ? e.message : "Failed to load";
}

if (!page && !loadError) {
	Astro.response.status = 404;
}

const bodyHtml = page ? marked.parse(page.body ?? "") : "";
---

<Base title={page ? `${page.title} - Inaka Properties` : "Terms - Inaka Properties"}>
	<article class="legal">
		{page ? (
			<>
				<header class="legal-head">
					<h1>{page.title}</h1>
					{page.subtitle && <p class="lede">{page.subtitle}</p>}
				</header>
				<div class="legal-body" set:html={bodyHtml} />
			</>
		) : (
			<>
				<h1>Terms</h1>
				<p class="lede">{loadError ?? "This page is not currently available."}</p>
			</>
		)}
	</article>
</Base>

<style>
	.legal {
		max-width: 42rem;
		margin: 0 auto;
		padding: 3.5rem 0 2rem;
	}
	.legal-head {
		margin-bottom: 2.5rem;
	}
	.legal h1 {
		font-size: clamp(2rem, 4vw, 2.75rem);
		margin: 0 0 0.6rem;
		line-height: 1.15;
	}
	.lede {
		margin: 0;
		color: var(--muted);
		font-size: 1.08rem;
		line-height: 1.55;
	}
	.legal-body {
		font-size: 1rem;
		line-height: 1.7;
		color: var(--fg);
	}
	.legal-body :global(h2) {
		font-size: 1.3rem;
		margin: 2.2rem 0 0.8rem;
	}
	.legal-body :global(h3) {
		font-size: 1.08rem;
		margin: 1.8rem 0 0.6rem;
	}
	.legal-body :global(p) {
		margin: 0 0 1.1rem;
	}
	.legal-body :global(ul),
	.legal-body :global(ol) {
		margin: 0 0 1.1rem;
		padding-left: 1.4rem;
	}
	.legal-body :global(li) {
		margin: 0.3rem 0;
	}
	.legal-body :global(a) {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.legal-body :global(strong) {
		color: var(--fg);
	}
	.legal-body :global(hr) {
		border: 0;
		border-top: 1px solid var(--line);
		margin: 2rem 0;
	}
	.legal-body :global(code) {
		background: var(--accent-soft);
		padding: 0.1rem 0.35rem;
		border-radius: 4px;
		font-size: 0.92em;
	}
</style>
