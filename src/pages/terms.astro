---
import Base from "../layouts/Base.astro";
import { marked } from "marked";
import {
	fetchPage,
	readDemoOverride,
	type KuraEnv,
	type DemoOverride,
} from "../lib/kura";

const env = Astro.locals.runtime?.env as KuraEnv | undefined;
const cookieHeader = Astro.request.headers.get("cookie") ?? undefined;
const override: DemoOverride | undefined = readDemoOverride(Astro.url, cookieHeader);

Astro.response.headers.set("Cache-Control", "no-cache, must-revalidate");

let page = null;
let loadError: string | null = null;
try {
	page = await fetchPage(env ?? {}, "terms", override);
} catch (e) {
	loadError = e instanceof Error ? e.message : "Failed to load";
}

if (!page && !loadError) {
	Astro.response.status = 404;
}

const bodyHtml = page ? marked.parse(page.body ?? "") : "";
---

<Base title={page ? `${page.title} - Inaka Properties` : "Terms - Inaka Properties"}>
	<article class="legal">
		{page ? (
			<>
				<header class="legal-head">
					<h1>{page.title}</h1>
					{page.subtitle && <p class="lede">{page.subtitle}</p>}
				</header>
				<div class="legal-body" set:html={bodyHtml} />
			</>
		) : (
			<>
				<h1>Terms</h1>
				<p class="lede">{loadError ?? "This page is not currently available."}</p>
			</>
		)}
	</article>
</Base>

<style>
	.legal {
		max-width: 42rem;
		margin: 0 auto;
		padding: 4.5rem 0 2rem;
	}
	.legal-head {
		margin-bottom: 3rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--rule);
	}
	.legal h1 {
		font-family: var(--serif);
		font-size: clamp(2.3rem, 4.8vw, 3.2rem);
		margin: 0 0 0.9rem;
		line-height: 1.05;
		letter-spacing: -0.008em;
		font-weight: 500;
	}
	.lede {
		margin: 0;
		color: var(--slate);
		font-size: 1.05rem;
		line-height: 1.55;
		font-family: var(--serif);
		font-style: italic;
	}
	.legal-body {
		font-family: var(--sans);
		font-size: 1rem;
		line-height: 1.75;
		color: var(--ink-2);
	}
	.legal-body :global(h2) {
		font-family: var(--serif);
		font-size: 1.55rem;
		font-weight: 500;
		margin: 2.5rem 0 0.9rem;
		color: var(--ink);
	}
	.legal-body :global(h3) {
		font-family: var(--serif);
		font-size: 1.2rem;
		font-weight: 500;
		margin: 2rem 0 0.7rem;
		color: var(--ink);
	}
	.legal-body :global(p) {
		margin: 0 0 1.1rem;
	}
	.legal-body :global(ul),
	.legal-body :global(ol) {
		margin: 0 0 1.1rem;
		padding-left: 1.4rem;
	}
	.legal-body :global(li) {
		margin: 0.3rem 0;
	}
	.legal-body :global(a) {
		color: var(--accent-deep);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-thickness: 1px;
	}
	.legal-body :global(strong) {
		color: var(--ink);
		font-weight: 600;
	}
	.legal-body :global(hr) {
		border: 0;
		border-top: 1px solid var(--rule);
		margin: 2.5rem 0;
	}
	.legal-body :global(code) {
		background: var(--accent-soft);
		padding: 0.1rem 0.35rem;
		border-radius: 4px;
		font-size: 0.92em;
	}
</style>
