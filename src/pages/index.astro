---
import Base from "../layouts/Base.astro";
import {
	fetchListings,
	formatJpy,
	statusLabel,
	prefectureLabel,
	PREFECTURES,
	type KuraEnv,
	type Listing,
} from "../lib/kura";

const env = Astro.locals.runtime?.env as KuraEnv | undefined;
const url = Astro.url;
const params = url.searchParams;

const status = params.get("status") ?? "";
const prefecture = params.get("prefecture") ?? "";
const minPrice = params.get("min") ?? "";
const maxPrice = params.get("max") ?? "";
const sort = params.get("sort") || "price_jpy:asc";

const query: Record<string, string | number> = { sort, limit: 30 };
if (status) query.status = status;
if (prefecture) query.prefecture = prefecture;
if (minPrice) query["price_jpy[gte]"] = Number(minPrice);
if (maxPrice) query["price_jpy[lte]"] = Number(maxPrice);

let listings: Listing[] = [];
let loadError: string | null = null;
try {
	listings = await fetchListings(env ?? {}, query);
} catch (e) {
	loadError = e instanceof Error ? e.message : "Failed to load";
}

const totalAvailable = listings.filter((l) => l.status === "available").length;
const anyFilter = !!(status || prefecture || minPrice || maxPrice);
---

<Base title="Inaka - country houses in Japan">
	<section class="hero">
		<p class="eyebrow">Demo · {listings.length} listings · {totalAvailable} available</p>
		<h1>Country houses, slowly chosen.</h1>
		<p class="lede">
			Vacant houses and akiya in rural Japan, each written up by hand. Every listing on this
			site is fictional - it lives in a <a href="https://kuracms.com">kura</a> project so a
			non-technical editor could change any of it in seconds.
		</p>
	</section>

	<form class="filters" method="get">
		<label>
			<span>Status</span>
			<select name="status">
				<option value="">All</option>
				<option value="available" selected={status === "available"}>Available</option>
				<option value="under_offer" selected={status === "under_offer"}>Under offer</option>
				<option value="sold" selected={status === "sold"}>Sold</option>
			</select>
		</label>
		<label>
			<span>Prefecture</span>
			<select name="prefecture">
				<option value="">All</option>
				{PREFECTURES.map((p) => (
					<option value={p.value} selected={prefecture === p.value}>{p.label}</option>
				))}
			</select>
		</label>
		<label>
			<span>Min ¥</span>
			<input name="min" type="number" inputmode="numeric" value={minPrice} placeholder="any" />
		</label>
		<label>
			<span>Max ¥</span>
			<input name="max" type="number" inputmode="numeric" value={maxPrice} placeholder="any" />
		</label>
		<label>
			<span>Sort</span>
			<select name="sort">
				<option value="price_jpy:asc" selected={sort === "price_jpy:asc"}>Price low to high</option>
				<option value="price_jpy:desc" selected={sort === "price_jpy:desc"}>Price high to low</option>
				<option value="build_year:desc" selected={sort === "build_year:desc"}>Newer first</option>
				<option value="build_year:asc" selected={sort === "build_year:asc"}>Older first</option>
				<option value="square_meters:desc" selected={sort === "square_meters:desc"}>Larger first</option>
			</select>
		</label>
		<div class="filter-actions">
			<button type="submit">Apply</button>
			{anyFilter && <a href="/">Reset</a>}
		</div>
	</form>

	{loadError && <p class="err">Couldn't load listings: {loadError}</p>}

	{listings.length === 0 && !loadError && (
		<p class="muted">No listings match those filters.</p>
	)}

	<section class="grid">
		{listings.map((l) => (
			<a class="card" href={`/listings/${l.slug}`}>
				<div class="photo">
					{l.hero_image ? (
						<img src={l.hero_image as string} alt={l.title} loading="lazy" />
					) : (
						<div class="photo-placeholder"></div>
					)}
					<span class={`status status-${l.status}`}>{statusLabel(l.status)}</span>
				</div>
				<div class="body">
					<p class="loc">{prefectureLabel(l.prefecture)} · {l.location.split(",")[0]}</p>
					<h2>{l.title}</h2>
					<p class="price">{formatJpy(l.price_jpy)}</p>
					<dl>
						{l.layout && <div><dt>Layout</dt><dd>{l.layout}</dd></div>}
						{l.square_meters && <div><dt>Floor</dt><dd>{l.square_meters} m²</dd></div>}
						{l.land_area_sqm && <div><dt>Land</dt><dd>{l.land_area_sqm.toLocaleString()} m²</dd></div>}
						{l.build_year && <div><dt>Built</dt><dd>{l.build_year}</dd></div>}
					</dl>
				</div>
			</a>
		))}
	</section>
</Base>

<style>
	.hero {
		padding: 2rem 0 3rem;
		max-width: 40rem;
	}
	.eyebrow {
		font-size: 0.78rem;
		color: var(--faint);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin: 0 0 1rem;
	}
	.hero h1 {
		font-size: clamp(2.2rem, 5.5vw, 3.4rem);
		margin: 0 0 1rem;
		line-height: 1.04;
	}
	.lede {
		color: var(--muted);
		line-height: 1.6;
		font-size: 1.05rem;
		margin: 0;
	}
	.lede a {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.filters {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
		gap: 0.75rem 1rem;
		padding: 1rem 1.25rem;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: 12px;
		margin-bottom: 2rem;
		align-items: end;
	}
	.filters label {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		font-size: 0.85rem;
	}
	.filters label > span {
		color: var(--muted);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.filters input,
	.filters select {
		font: inherit;
		padding: 0.45rem 0.6rem;
		background: var(--bg);
		color: var(--fg);
		border: 1px solid var(--line);
		border-radius: 7px;
	}
	.filter-actions {
		display: flex;
		gap: 0.75rem;
		align-items: center;
	}
	.filter-actions button {
		background: var(--accent);
		color: var(--card);
		border: 0;
		padding: 0.55rem 1.1rem;
		border-radius: 7px;
		font: inherit;
		cursor: pointer;
	}
	.filter-actions a {
		color: var(--muted);
		font-size: 0.85rem;
		text-decoration: none;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
		gap: 1.5rem;
	}
	.card {
		text-decoration: none;
		color: inherit;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: 12px;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.card:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
	}
	.photo {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: var(--accent-soft);
	}
	.photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.photo-placeholder {
		width: 100%;
		height: 100%;
		background:
			linear-gradient(135deg, var(--accent) 0%, var(--muted) 100%);
	}
	.status {
		position: absolute;
		top: 0.75rem;
		left: 0.75rem;
		background: var(--badge-available);
		color: #fff;
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		padding: 0.25rem 0.55rem;
		border-radius: 4px;
		font-weight: 600;
	}
	.status-under_offer {
		background: var(--badge-under-offer);
	}
	.status-sold {
		background: var(--badge-sold);
	}
	.body {
		padding: 1.1rem 1.25rem 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.loc {
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
		margin: 0;
	}
	.card h2 {
		font-size: 1.15rem;
		margin: 0;
		line-height: 1.3;
	}
	.price {
		font-size: 1.15rem;
		font-weight: 600;
		margin: 0;
		color: var(--accent);
	}
	dl {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0.35rem 0.5rem;
		margin: 0.3rem 0 0;
		padding: 0;
	}
	dt {
		color: var(--faint);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin: 0;
	}
	dd {
		margin: 0;
		font-size: 0.9rem;
	}
	.muted {
		color: var(--muted);
		padding: 2rem 0;
		text-align: center;
	}
	.err {
		color: var(--badge-under-offer);
		background: var(--accent-soft);
		padding: 0.75rem 1rem;
		border-radius: 8px;
	}
</style>
