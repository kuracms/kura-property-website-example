---
import Base from "../layouts/Base.astro";
import { marked } from "marked";
import {
	fetchListings,
	fetchPage,
	formatJpy,
	statusLabel,
	prefectureLabel,
	readDemoOverride,
	serializeDemoOverride,
	isDeadProjectError,
	type KuraEnv,
	type Listing,
	type Page,
	type DemoOverride,
} from "../lib/kura";

const env = Astro.locals.runtime?.env as KuraEnv | undefined;
const url = Astro.url;
const params = url.searchParams;

const cookieHeader = Astro.request.headers.get("cookie") ?? undefined;
let override: DemoOverride | undefined = readDemoOverride(url, cookieHeader);
// Tell browsers and any intermediate cache to revalidate on every request -
// editors expect their changes to show on next page load without Ctrl+Shift+R.
Astro.response.headers.set("Cache-Control", "no-cache, must-revalidate");
// Persist override so the visitor can navigate without re-passing the query
if (override && url.searchParams.has("project") && url.searchParams.has("token")) {
	Astro.cookies.set("kura_demo_preview", serializeDemoOverride(override), {
		path: "/",
		httpOnly: false,
		sameSite: "lax",
		secure: url.protocol === "https:",
		maxAge: 60 * 60 * 24,
	});
}

const status = params.get("status") ?? "";
const prefSlug = params.get("prefecture") ?? "";
const minPrice = params.get("min") ?? "";
const maxPrice = params.get("max") ?? "";
const sort = params.get("sort") || "price_jpy:asc";

const query: Record<string, string | number> = { sort, limit: 50 };
if (status) query.status = status;
if (prefSlug) query.prefecture_slug = prefSlug;
if (minPrice) query["price_jpy[gte]"] = Number(minPrice);
if (maxPrice) query["price_jpy[lte]"] = Number(maxPrice);

let listings: Listing[] = [];
let loadError: string | null = null;
try {
	listings = await fetchListings(env ?? {}, query, override);
} catch (e) {
	if (override?.source === "cookie" && isDeadProjectError(e)) {
		Astro.cookies.delete("kura_demo_preview", { path: "/" });
		override = undefined;
		try {
			listings = await fetchListings(env ?? {}, query, undefined);
		} catch (e2) {
			loadError = e2 instanceof Error ? e2.message : "Failed to load";
		}
	} else {
		loadError = e instanceof Error ? e.message : "Failed to load";
	}
}

// Editable home page from kura - title/subtitle/body markdown
let home: Page | null = null;
try {
	home = await fetchPage(env ?? {}, "home", override);
} catch {
	// Non-fatal - we fall back to hard-coded copy below
	home = null;
}
const heroTitle = home?.title || "Vacant houses for sale across rural Japan.";
const heroEyebrow = home?.subtitle || "Rural Japan, quietly for sale";
const heroBodyHtml = home?.body ? marked.parse(home.body) : "";

// Build the prefecture dropdown from the actual data
let allPrefs: { slug: string; label: string }[] = [];
try {
	const all = await fetchListings(env ?? {}, { limit: 100 }, override);
	const set = new Map<string, string>();
	for (const l of all) {
		if (l.prefecture_slug && !set.has(l.prefecture_slug)) {
			set.set(l.prefecture_slug, prefectureLabel(l.prefecture_slug));
		}
	}
	allPrefs = [...set.entries()]
		.map(([slug, label]) => ({ slug, label }))
		.sort((a, b) => a.label.localeCompare(b.label));
} catch {}

const totalAvailable = listings.filter((l) => l.status === "available").length;
const anyFilter = !!(status || prefSlug || minPrice || maxPrice);
---

<Base title={`${heroTitle} - Inaka Properties`}>
	<section class="hero">
		<p class="eyebrow">{heroEyebrow}</p>
		<h1>{heroTitle}</h1>
		{heroBodyHtml ? (
			<div class="lede" set:html={heroBodyHtml} />
		) : (
			<p class="lede">
				Properties from every corner of the country, listed for sale through
				Inaka. A demonstration site backed by <a href="https://kuracms.com">kura</a>.
			</p>
		)}
		<p class="hero-meta">
			<span>{listings.length} listings</span>
			<span class="dot"></span>
			<span>{totalAvailable} available</span>
		</p>
	</section>

	<div class="rule"></div>

	<form class="filters" method="get">
		<label>
			<span>Status</span>
			<select name="status">
				<option value="">All</option>
				<option value="available" selected={status === "available"}>Available</option>
				<option value="under_offer" selected={status === "under_offer"}>Under offer</option>
				<option value="sold" selected={status === "sold"}>Sold</option>
			</select>
		</label>
		<label>
			<span>Prefecture</span>
			<select name="prefecture">
				<option value="">All</option>
				{allPrefs.map((p) => (
					<option value={p.slug} selected={prefSlug === p.slug}>{p.label}</option>
				))}
			</select>
		</label>
		<label>
			<span>Min ¥</span>
			<input name="min" type="number" inputmode="numeric" value={minPrice} placeholder="any" />
		</label>
		<label>
			<span>Max ¥</span>
			<input name="max" type="number" inputmode="numeric" value={maxPrice} placeholder="any" />
		</label>
		<label>
			<span>Sort</span>
			<select name="sort">
				<option value="price_jpy:asc" selected={sort === "price_jpy:asc"}>Price low to high</option>
				<option value="price_jpy:desc" selected={sort === "price_jpy:desc"}>Price high to low</option>
				<option value="land_area_sqm:desc" selected={sort === "land_area_sqm:desc"}>Largest land</option>
				<option value="square_meters:desc" selected={sort === "square_meters:desc"}>Largest building</option>
				<option value="build_year:desc" selected={sort === "build_year:desc"}>Newer first</option>
				<option value="build_year:asc" selected={sort === "build_year:asc"}>Older first</option>
			</select>
		</label>
		<div class="filter-actions">
			<button type="submit">Apply</button>
			{anyFilter && <a href="/">Reset</a>}
		</div>
	</form>

	{loadError && <p class="err">Couldn't load listings: {loadError}</p>}

	{listings.length === 0 && !loadError && (
		<p class="muted">No listings match those filters.</p>
	)}

	<section class="grid">
		{listings.map((l, i) => (
			<a class="card" href={`/listings/${l.slug}`}>
				<div class="photo">
					{l.hero_image ? (
						<img src={l.hero_image as string} alt={l.title} loading="lazy" />
					) : (
						<div class="photo-placeholder"></div>
					)}
					<span class={`status status-${l.status}`}>{statusLabel(l.status)}</span>
					<span class="price-tag">{formatJpy(l.price_jpy)}</span>
					<span class="card-index">N{String(i + 1).padStart(2, "0")}</span>
				</div>
				<div class="body">
					<p class="loc">{l.location}</p>
					<h2>{l.title}</h2>
					<dl>
						{l.layout && <div><dt>Layout</dt><dd>{l.layout}</dd></div>}
						{l.square_meters && <div><dt>Floor</dt><dd>{l.square_meters} m<sup>2</sup></dd></div>}
						{l.land_area_sqm && <div><dt>Land</dt><dd>{l.land_area_sqm.toLocaleString()} m<sup>2</sup></dd></div>}
						{l.build_year && <div><dt>Built</dt><dd>{l.build_year}</dd></div>}
					</dl>
				</div>
			</a>
		))}
	</section>
</Base>

<style>
	.hero {
		padding: 4.5rem 0 3rem;
		max-width: 50rem;
	}
	.eyebrow {
		font-family: var(--sans);
		font-size: 0.7rem;
		color: var(--slate);
		text-transform: uppercase;
		letter-spacing: 0.28em;
		margin: 0 0 1.6rem;
		font-weight: 500;
	}
	.hero h1 {
		font-family: var(--serif);
		font-size: clamp(2.8rem, 6.5vw, 4.6rem);
		margin: 0 0 1.5rem;
		line-height: 1;
		letter-spacing: -0.012em;
		font-weight: 500;
	}
	.lede {
		color: var(--ink-2);
		line-height: 1.65;
		font-size: 1.05rem;
		margin: 0;
		max-width: 38rem;
		font-family: var(--sans);
	}
	.lede :global(p) {
		margin: 0 0 1rem;
	}
	.lede :global(p:last-child) {
		margin-bottom: 0;
	}
	.lede :global(a) {
		color: var(--accent-deep);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-thickness: 1px;
	}
	.hero-meta {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		margin: 2rem 0 0;
		font-family: var(--sans);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--slate);
		font-weight: 500;
	}
	.hero-meta .dot {
		width: 3px;
		height: 3px;
		background: var(--slate-soft);
		border-radius: 50%;
		display: inline-block;
	}
	.rule {
		border-top: 1px solid var(--rule);
		margin: 0 0 2.25rem;
	}

	.filters {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
		gap: 0.65rem 1.4rem;
		padding: 0 0 2rem;
		margin-bottom: 2.5rem;
		align-items: end;
		border-bottom: 1px solid var(--rule);
	}
	.filters label {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		font-size: 0.88rem;
		position: relative;
		font-family: var(--sans);
	}
	.filters label > span {
		color: var(--slate);
		font-size: 0.62rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-weight: 500;
	}
	.filters input,
	.filters select {
		font: inherit;
		padding: 0.55rem 0.1rem;
		background: transparent;
		color: var(--ink);
		border: 0;
		border-bottom: 1px solid var(--rule);
		border-radius: 0;
		transition: border-color 0.15s;
	}
	.filters select {
		appearance: none;
		-webkit-appearance: none;
		-moz-appearance: none;
		padding-right: 1.4rem;
		cursor: pointer;
	}
	.filters label:has(> select)::after {
		content: "";
		position: absolute;
		right: 0.4rem;
		bottom: 0.85rem;
		width: 0.4rem;
		height: 0.4rem;
		border-right: 1.4px solid var(--slate);
		border-bottom: 1.4px solid var(--slate);
		transform: translateY(-50%) rotate(45deg);
		pointer-events: none;
	}
	.filters input:focus,
	.filters select:focus {
		outline: none;
		border-bottom-color: var(--accent);
	}
	.filter-actions {
		display: flex;
		gap: 1rem;
		align-items: baseline;
	}
	.filter-actions button {
		background: var(--ink);
		color: var(--paper);
		border: 1px solid var(--ink);
		padding: 0.7rem 1.35rem;
		border-radius: 0;
		font: inherit;
		font-family: var(--sans);
		font-size: 0.68rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		cursor: pointer;
		transition: background 0.15s, border-color 0.15s;
	}
	.filter-actions button:hover {
		background: var(--accent);
		border-color: var(--accent);
	}
	.filter-actions a {
		color: var(--slate);
		font-size: 0.7rem;
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		border-bottom: 1px solid var(--rule);
		padding-bottom: 2px;
	}
	.filter-actions a:hover {
		color: var(--ink);
		border-bottom-color: var(--accent);
	}

	/* ---------- Editorial card grid ---------- */
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
		gap: 3.5rem 2.5rem;
		margin-bottom: 4rem;
	}
	.card {
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		transition: opacity 0.18s ease;
	}
	.card:hover {
		opacity: 0.94;
	}
	.photo {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: var(--paper-2);
	}
	.photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.6s ease;
		filter: saturate(0.92);
	}
	.card:hover .photo img {
		transform: scale(1.025);
		filter: saturate(1);
	}
	.photo-placeholder {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, var(--paper-2) 0%, var(--rule) 100%);
	}
	.status {
		position: absolute;
		top: 0.9rem;
		left: 0.9rem;
		background: var(--ink);
		color: var(--paper);
		font-family: var(--sans);
		font-size: 0.62rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		padding: 0.32rem 0.65rem;
		font-weight: 500;
	}
	.status-under_offer {
		background: var(--accent);
	}
	.status-sold {
		background: var(--slate-soft);
		color: var(--ink);
	}
	.card-index {
		position: absolute;
		top: 0.9rem;
		right: 0.9rem;
		font-family: var(--sans);
		font-size: 0.62rem;
		letter-spacing: 0.18em;
		color: var(--paper);
		mix-blend-mode: difference;
		font-weight: 500;
	}
	/* Vertical price label down the right edge of the photo */
	.price-tag {
		position: absolute;
		right: 0;
		bottom: 0;
		background: var(--accent);
		color: var(--paper);
		font-family: var(--sans);
		font-weight: 500;
		font-size: 0.78rem;
		letter-spacing: 0.04em;
		padding: 0.55rem 0.85rem;
		writing-mode: horizontal-tb;
	}
	.body {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 0 0.1rem;
	}
	.loc {
		font-family: var(--sans);
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.22em;
		color: var(--slate);
		margin: 0;
		font-weight: 500;
	}
	.card h2 {
		font-family: var(--serif);
		font-size: 1.5rem;
		margin: 0;
		line-height: 1.2;
		font-weight: 500;
		letter-spacing: -0.005em;
		color: var(--ink);
	}
	dl {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0.6rem 1.2rem;
		margin: 0.65rem 0 0;
		padding: 0.8rem 0 0;
		border-top: 1px solid var(--rule);
		font-family: var(--sans);
	}
	dl > div {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}
	dt {
		color: var(--slate-soft);
		font-size: 0.58rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		margin: 0;
		font-weight: 500;
	}
	dd {
		margin: 0;
		font-size: 0.92rem;
		font-weight: 400;
		color: var(--ink-2);
	}
	dd sup {
		font-size: 0.7em;
	}
	.muted {
		color: var(--slate);
		padding: 2rem 0;
		text-align: center;
		font-family: var(--sans);
	}
	.err {
		color: var(--accent-deep);
		background: var(--accent-soft);
		padding: 0.75rem 1rem;
		border-left: 2px solid var(--accent);
		font-family: var(--sans);
	}
</style>
