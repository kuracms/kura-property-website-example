---
import Base from "../layouts/Base.astro";
import {
	fetchListings,
	formatJpy,
	statusLabel,
	prefectureLabel,
	readDemoOverride,
	serializeDemoOverride,
	isDeadProjectError,
	type KuraEnv,
	type Listing,
	type DemoOverride,
} from "../lib/kura";

const env = Astro.locals.runtime?.env as KuraEnv | undefined;
const url = Astro.url;
const params = url.searchParams;

const cookieHeader = Astro.request.headers.get("cookie") ?? undefined;
let override: DemoOverride | undefined = readDemoOverride(url, cookieHeader);
// Tell browsers and any intermediate cache to revalidate on every request -
// editors expect their changes to show on next page load without Ctrl+Shift+R.
Astro.response.headers.set("Cache-Control", "no-cache, must-revalidate");
// Persist override so the visitor can navigate without re-passing the query
if (override && url.searchParams.has("project") && url.searchParams.has("token")) {
	Astro.cookies.set("kura_demo_preview", serializeDemoOverride(override), {
		path: "/",
		httpOnly: false,
		sameSite: "lax",
		secure: url.protocol === "https:",
		maxAge: 60 * 60 * 24,
	});
}

const status = params.get("status") ?? "";
const prefSlug = params.get("prefecture") ?? "";
const minPrice = params.get("min") ?? "";
const maxPrice = params.get("max") ?? "";
const sort = params.get("sort") || "price_jpy:asc";

const query: Record<string, string | number> = { sort, limit: 50 };
if (status) query.status = status;
if (prefSlug) query.prefecture_slug = prefSlug;
if (minPrice) query["price_jpy[gte]"] = Number(minPrice);
if (maxPrice) query["price_jpy[lte]"] = Number(maxPrice);

let listings: Listing[] = [];
let loadError: string | null = null;
try {
	listings = await fetchListings(env ?? {}, query, override);
} catch (e) {
	// If the override came from a stale cookie (sandbox expired), drop the
	// cookie and retry against the canonical project. The visitor sees the
	// public site instead of a 404.
	if (override?.source === "cookie" && isDeadProjectError(e)) {
		Astro.cookies.delete("kura_demo_preview", { path: "/" });
		override = undefined;
		try {
			listings = await fetchListings(env ?? {}, query, undefined);
		} catch (e2) {
			loadError = e2 instanceof Error ? e2.message : "Failed to load";
		}
	} else {
		loadError = e instanceof Error ? e.message : "Failed to load";
	}
}

// Build the prefecture dropdown from the actual data
let allPrefs: { slug: string; label: string }[] = [];
try {
	const all = await fetchListings(env ?? {}, { limit: 100 }, override);
	const set = new Map<string, string>();
	for (const l of all) {
		if (l.prefecture_slug && !set.has(l.prefecture_slug)) {
			set.set(l.prefecture_slug, prefectureLabel(l.prefecture_slug));
		}
	}
	allPrefs = [...set.entries()]
		.map(([slug, label]) => ({ slug, label }))
		.sort((a, b) => a.label.localeCompare(b.label));
} catch {}

const totalAvailable = listings.filter((l) => l.status === "available").length;
const anyFilter = !!(status || prefSlug || minPrice || maxPrice);
---

<Base title="Inaka Properties - vacant houses for sale in rural Japan">
	<section class="hero">
		<p class="eyebrow">{listings.length} listings · {totalAvailable} available</p>
		<h1>Vacant houses for sale across rural Japan.</h1>
		<p class="lede">
			Properties from every corner of the country, listed for sale through
			Inaka. This is a demonstration site backed by
			<a href="https://kuracms.com">kura</a> - the listings, descriptions and
			prices are fictitious, but the frontend and the admin interface
			are real working software.
		</p>
	</section>

	<form class="filters" method="get">
		<label>
			<span>Status</span>
			<select name="status">
				<option value="">All</option>
				<option value="available" selected={status === "available"}>Available</option>
				<option value="under_offer" selected={status === "under_offer"}>Under offer</option>
				<option value="sold" selected={status === "sold"}>Sold</option>
			</select>
		</label>
		<label>
			<span>Prefecture</span>
			<select name="prefecture">
				<option value="">All</option>
				{allPrefs.map((p) => (
					<option value={p.slug} selected={prefSlug === p.slug}>{p.label}</option>
				))}
			</select>
		</label>
		<label>
			<span>Min ¥</span>
			<input name="min" type="number" inputmode="numeric" value={minPrice} placeholder="any" />
		</label>
		<label>
			<span>Max ¥</span>
			<input name="max" type="number" inputmode="numeric" value={maxPrice} placeholder="any" />
		</label>
		<label>
			<span>Sort</span>
			<select name="sort">
				<option value="price_jpy:asc" selected={sort === "price_jpy:asc"}>Price low to high</option>
				<option value="price_jpy:desc" selected={sort === "price_jpy:desc"}>Price high to low</option>
				<option value="land_area_sqm:desc" selected={sort === "land_area_sqm:desc"}>Largest land</option>
				<option value="square_meters:desc" selected={sort === "square_meters:desc"}>Largest building</option>
				<option value="build_year:desc" selected={sort === "build_year:desc"}>Newer first</option>
				<option value="build_year:asc" selected={sort === "build_year:asc"}>Older first</option>
			</select>
		</label>
		<div class="filter-actions">
			<button type="submit">Apply</button>
			{anyFilter && <a href="/">Reset</a>}
		</div>
	</form>

	{loadError && <p class="err">Couldn't load listings: {loadError}</p>}

	{listings.length === 0 && !loadError && (
		<p class="muted">No listings match those filters.</p>
	)}

	<section class="grid">
		{listings.map((l) => (
			<a class="card" href={`/listings/${l.slug}`}>
				<div class="photo">
					{l.hero_image ? (
						<img src={l.hero_image as string} alt={l.title} loading="lazy" />
					) : (
						<div class="photo-placeholder"></div>
					)}
					<span class={`status status-${l.status}`}>{statusLabel(l.status)}</span>
				</div>
				<div class="body">
					<p class="loc">{l.location}</p>
					<h2>{l.title}</h2>
					<p class="price">{formatJpy(l.price_jpy)}</p>
					<dl>
						{l.layout && <div><dt>Layout</dt><dd>{l.layout}</dd></div>}
						{l.square_meters && <div><dt>Floor</dt><dd>{l.square_meters} m²</dd></div>}
						{l.land_area_sqm && <div><dt>Land</dt><dd>{l.land_area_sqm.toLocaleString()} m²</dd></div>}
						{l.build_year && <div><dt>Built</dt><dd>{l.build_year}</dd></div>}
					</dl>
				</div>
			</a>
		))}
	</section>
</Base>

<style>
	.hero {
		padding: 3rem 0 3.5rem;
		max-width: 44rem;
	}
	.eyebrow {
		font-size: 0.78rem;
		color: var(--faint);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		margin: 0 0 1rem;
	}
	.hero h1 {
		font-size: clamp(2.2rem, 5vw, 3.3rem);
		margin: 0 0 1.25rem;
		line-height: 1.05;
	}
	.lede {
		color: var(--muted);
		line-height: 1.65;
		font-size: 1.05rem;
		margin: 0;
		max-width: 38rem;
	}
	.lede a {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.filters {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
		gap: 0.75rem 1rem;
		padding: 1.1rem 1.35rem;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: 14px;
		margin-bottom: 2.5rem;
		align-items: end;
	}
	.filters label {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		font-size: 0.85rem;
		position: relative;
	}
	.filters label > span {
		color: var(--muted);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 500;
	}
	.filters input,
	.filters select {
		font: inherit;
		padding: 0.5rem 0.65rem;
		background: var(--bg);
		color: var(--fg);
		border: 1px solid var(--line);
		border-radius: 8px;
		transition: border-color 0.15s;
	}
	.filters select {
		appearance: none;
		-webkit-appearance: none;
		-moz-appearance: none;
		padding-right: 1.8rem;
		cursor: pointer;
	}
	.filters label:has(> select)::after {
		content: "";
		position: absolute;
		right: 0.85rem;
		bottom: 1rem;
		width: 0.45rem;
		height: 0.45rem;
		border-right: 1.6px solid var(--muted);
		border-bottom: 1.6px solid var(--muted);
		transform: translateY(-50%) rotate(45deg);
		pointer-events: none;
	}
	.filters input:focus,
	.filters select:focus {
		outline: none;
		border-color: var(--accent);
	}
	.filter-actions {
		display: flex;
		gap: 0.85rem;
		align-items: center;
	}
	.filter-actions button {
		background: var(--accent);
		color: var(--card);
		border: 0;
		padding: 0.6rem 1.25rem;
		border-radius: 8px;
		font: inherit;
		font-weight: 500;
		cursor: pointer;
		transition: filter 0.15s;
	}
	.filter-actions button:hover {
		filter: brightness(1.1);
	}
	.filter-actions a {
		color: var(--muted);
		font-size: 0.85rem;
		text-decoration: none;
	}
	.filter-actions a:hover {
		color: var(--fg);
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
		gap: 1.5rem;
		margin-bottom: 4rem;
	}
	.card {
		text-decoration: none;
		color: inherit;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: 12px;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease,
			border-color 0.18s ease;
	}
	.card:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
		border-color: #d8d0bd;
	}
	.photo {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: var(--accent-soft);
	}
	.photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.5s ease;
	}
	.card:hover .photo img {
		transform: scale(1.03);
	}
	.photo-placeholder {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, var(--accent) 0%, var(--muted) 100%);
	}
	.status {
		position: absolute;
		top: 0.85rem;
		left: 0.85rem;
		background: var(--badge-available);
		color: #fff;
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.28rem 0.6rem;
		border-radius: 5px;
		font-weight: 600;
		backdrop-filter: blur(8px);
	}
	.status-under_offer {
		background: var(--badge-under-offer);
	}
	.status-sold {
		background: var(--badge-sold);
	}
	.body {
		padding: 1.1rem 1.3rem 1.35rem;
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}
	.loc {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--muted);
		margin: 0;
		font-weight: 500;
	}
	.card h2 {
		font-size: 1.1rem;
		margin: 0;
		line-height: 1.35;
	}
	.price {
		font-size: 1.15rem;
		font-weight: 700;
		margin: 0.1rem 0 0;
		color: var(--accent);
	}
	dl {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0.45rem 0.7rem;
		margin: 0.4rem 0 0;
		padding: 0;
	}
	dt {
		color: var(--faint);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		margin: 0;
	}
	dd {
		margin: 0;
		font-size: 0.9rem;
		font-weight: 500;
	}
	.muted {
		color: var(--muted);
		padding: 2rem 0;
		text-align: center;
	}
	.err {
		color: var(--badge-under-offer);
		background: var(--accent-soft);
		padding: 0.75rem 1rem;
		border-radius: 8px;
	}
</style>
