---
interface Props {
	title?: string;
	description?: string;
	fullBleed?: boolean; // /map - no shell padding, no footer
}
const {
	title = "Inaka Properties - vacant houses for sale in rural Japan",
	description = "Vacant houses for sale across rural Japan, served via a kura content backend.",
	fullBleed = false,
} = Astro.props;
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
		<meta name="description" content={description} />
		<style is:global>
			:root {
				/* Cool editorial palette - paper, ink, slate, with one warm accent */
				--paper: #f4f3ef;
				--paper-2: #eceae3;
				--ink: #15171a;
				--ink-2: #2a2d33;
				--slate: #5c636e;
				--slate-soft: #97a0a8;
				--rule: #d8d9d3;
				--rule-soft: #e6e5df;
				--card: #ffffff;
				--accent: #c45a3a;
				--accent-deep: #a8482c;
				--accent-soft: rgba(196, 90, 58, 0.08);

				/* Back-compat aliases used by remaining components */
				--bg: var(--paper);
				--fg: var(--ink);
				--muted: var(--slate);
				--faint: var(--slate-soft);
				--line: var(--rule);
				--header-bg: var(--paper);
				--badge-available: var(--ink);
				--badge-under-offer: var(--accent);
				--badge-sold: var(--slate-soft);

				--serif: "Cormorant Garamond", "Source Serif Pro", "Iowan Old Style",
					"Hiragino Mincho ProN", Georgia, serif;
				--sans: "Inter", ui-sans-serif, system-ui, -apple-system, "Hiragino Sans",
					"Yu Gothic", sans-serif;
			}
			* {
				box-sizing: border-box;
			}
			body {
				margin: 0;
				color: var(--ink);
				background: var(--paper);
				font-family: var(--sans);
				font-size: 16px;
				font-weight: 400;
				-webkit-font-smoothing: antialiased;
			}
			h1,
			h2,
			h3 {
				font-family: var(--serif);
				font-weight: 500;
				letter-spacing: -0.005em;
				color: var(--ink);
			}
			a {
				color: inherit;
			}
			.shell {
				max-width: 78rem;
				margin: 0 auto;
				padding: 0 clamp(1.25rem, 5vw, 4rem);
			}

			/* ---------- Demo banner (consistent across all five kura demos) ---- */
			.kura-demo-banner {
				background: #111;
				color: #d9d9d9;
				text-align: center;
				padding: 0.45rem 1rem;
				font-size: 0.78rem;
				letter-spacing: 0.02em;
			}
			.kura-demo-banner a {
				color: #fff;
				text-decoration: none;
				border-bottom: 1px solid rgba(255, 255, 255, 0.4);
				padding-bottom: 1px;
			}
			.kura-demo-banner a:hover {
				border-bottom-color: #fff;
			}

			/* ---------- Header: centred wordmark, hairline rule, tracked nav ---- */
			.site-header {
				position: sticky;
				top: 0;
				z-index: 30;
				background: var(--paper);
				border-bottom: 1px solid var(--rule);
			}
			.site-nav {
				display: grid;
				grid-template-columns: 1fr auto 1fr;
				align-items: center;
				padding: 1.4rem 0 1.15rem;
				gap: 1.5rem;
			}
			.site-meta {
				font-family: var(--sans);
				font-size: 0.68rem;
				text-transform: uppercase;
				letter-spacing: 0.22em;
				color: var(--slate);
				font-weight: 500;
			}
			.brand {
				text-decoration: none;
				display: inline-flex;
				flex-direction: column;
				align-items: center;
				line-height: 1;
				color: var(--ink);
			}
			.brand .mark {
				font-family: var(--serif);
				font-size: clamp(1.75rem, 3.2vw, 2.25rem);
				font-weight: 500;
				letter-spacing: 0.01em;
				font-style: italic;
				line-height: 1;
			}
			.brand .sub {
				font-family: var(--sans);
				font-size: 0.62rem;
				color: var(--slate);
				text-transform: uppercase;
				letter-spacing: 0.42em;
				font-weight: 500;
				margin-top: 0.45rem;
				padding-left: 0.42em; /* offset the trailing tracking */
			}
			.nav-links {
				display: flex;
				align-items: center;
				justify-content: flex-end;
				gap: 2.25rem;
				font-family: var(--sans);
				font-size: 0.72rem;
				text-transform: uppercase;
				letter-spacing: 0.22em;
				font-weight: 500;
			}
			.nav-links a {
				color: var(--slate);
				text-decoration: none;
				padding: 0.35rem 0;
				border-bottom: 1px solid transparent;
				transition: color 0.15s, border-color 0.15s;
			}
			.nav-links a:hover,
			.nav-links a:focus-visible {
				color: var(--ink);
				outline: none;
				border-bottom-color: var(--ink);
			}
			.nav-links a[aria-current="page"] {
				color: var(--ink);
				border-bottom-color: var(--accent);
			}
			@media (max-width: 720px) {
				.site-nav {
					grid-template-columns: 1fr;
					justify-items: center;
					gap: 0.9rem;
					padding: 1rem 0 0.9rem;
				}
				.site-meta {
					display: none;
				}
				.nav-links {
					justify-content: center;
					gap: 1.5rem;
					font-size: 0.66rem;
				}
			}

			/* ---------- Footer ---------- */
			footer {
				margin-top: 8rem;
				padding: 5rem 0 4rem;
				border-top: 1px solid var(--rule);
				color: var(--slate);
				font-family: var(--sans);
				font-size: 0.92rem;
				line-height: 1.7;
				background: var(--paper-2);
			}
			footer a {
				color: var(--ink);
				text-decoration: underline;
				text-decoration-color: var(--accent);
				text-underline-offset: 4px;
				text-decoration-thickness: 1px;
			}
			footer a:hover {
				color: var(--accent-deep);
			}
			.foot-pitch {
				max-width: 42rem;
				margin: 0 auto 4rem;
				text-align: center;
			}
			.foot-pitch p {
				margin: 0 0 1.1rem;
			}
			.foot-pitch p:last-child {
				margin-bottom: 0;
			}
			.foot-h {
				font-family: var(--serif);
				font-style: italic;
				font-size: clamp(1.5rem, 2.6vw, 1.85rem);
				color: var(--ink);
				font-weight: 500;
				margin-bottom: 1.5rem !important;
				line-height: 1.35;
				letter-spacing: -0.005em;
			}
			.foot-cta-wrap {
				margin-top: 2rem !important;
			}
			.foot-cta {
				display: inline-block;
				padding: 0.85rem 1.6rem;
				background: var(--ink);
				color: var(--paper) !important;
				font-family: var(--sans);
				font-size: 0.72rem;
				font-weight: 500;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				text-decoration: none !important;
				border: 1px solid var(--ink);
				transition: background 0.15s, color 0.15s, border-color 0.15s;
			}
			.foot-cta:hover {
				background: var(--accent);
				border-color: var(--accent);
				color: var(--paper) !important;
			}
			.foot-meta {
				padding-top: 2.5rem;
				border-top: 1px solid var(--rule);
				display: flex;
				flex-wrap: wrap;
				justify-content: space-between;
				align-items: baseline;
				gap: 1.5rem;
				font-size: 0.78rem;
				color: var(--slate-soft);
				line-height: 1.65;
			}
			.foot-disclaim {
				margin: 0;
				flex: 1 1 24rem;
				max-width: 48rem;
			}
			.foot-disclaim strong {
				color: var(--slate);
				font-weight: 600;
			}
			.foot-source {
				margin: 0;
				white-space: nowrap;
				font-size: 0.7rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
			}
			.foot-source a {
				text-decoration: none;
				border-bottom: 1px solid var(--rule);
				padding-bottom: 1px;
			}
			.foot-source a:hover {
				border-bottom-color: var(--accent);
			}
			@media (max-width: 720px) {
				footer {
					padding: 4rem 0 3rem;
					margin-top: 5rem;
				}
				.foot-pitch {
					margin-bottom: 3rem;
				}
			}
		</style>
	</head>
	<body>
		<div class="kura-demo-banner">
			<a href="https://kuracms.com" target="_blank" rel="noreferrer">
				This is a demonstration site for kura - see how it works at kuracms.com &rarr;
			</a>
		</div>
		<header class="site-header">
			<div class="shell">
				<div class="site-nav">
					<span class="site-meta">Est. for kura demo</span>
					<a class="brand" href="/">
						<span class="mark">Inaka</span>
						<span class="sub">Properties</span>
					</a>
					<nav class="nav-links">
						<a href="/" aria-current={path === "/" ? "page" : undefined}>Listings</a>
						<a href="/map" aria-current={path === "/map" ? "page" : undefined}>Map</a>
						<a href="https://github.com/kuracms/kura-property-website-example" rel="noreferrer">Source</a>
					</nav>
				</div>
			</div>
		</header>
		<main class={fullBleed ? "" : "shell"}>
			<slot />
		</main>
		{!fullBleed && (
			<footer>
				<div class="shell foot-shell">
					<div class="foot-pitch">
						<p class="foot-h">A demo site, powered by <a href="https://kuracms.com">kura</a>.</p>
						<p>
							This page is a working example of a small property frontend
							backed by <a href="https://kuracms.com">kura</a>, a hosted content
							backend. Your clients edit their own listings - words, photos,
							prices, status - through a clean admin interface. You build
							whatever frontend you like against the public API. No bespoke CMS
							to build, nothing to lose customer data over.
						</p>
						<p class="foot-cta-wrap">
							<a class="foot-cta" href="https://kuracms.com">See what kura can do</a>
						</p>
					</div>
					<div class="foot-meta">
						<p class="foot-disclaim">
							<strong>The listings on this site are fictitious.</strong>
							Photos and locations are representative; descriptions, prices and
							stories about previous owners are invented for the purposes of
							this demo. Nothing here is for sale.
						</p>
						<p class="foot-source">
							<a href="/privacy">Privacy</a>
							·
							<a href="/terms">Terms</a>
							·
							<a href="https://github.com/kuracms/kura-property-website-example">GitHub</a>
						</p>
					</div>
				</div>
			</footer>
		)}
	</body>
</html>
