---
interface Props {
	title?: string;
	description?: string;
	fullBleed?: boolean; // /map - no shell padding, no footer
}
const {
	title = "Inaka Properties - vacant houses for sale in rural Japan",
	description = "Vacant houses for sale across rural Japan, served via a kura content backend.",
	fullBleed = false,
} = Astro.props;
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<style is:global>
			:root {
				--bg: #faf7f1;
				--fg: #1c1a16;
				--muted: #645e51;
				--faint: #a09887;
				--line: #e9e2d3;
				--card: #ffffff;
				--accent: #2f4737;
				--accent-soft: rgba(47, 71, 55, 0.08);
				--accent-hover: #243a2c;
				--header-bg: #f5f0e3;
				--badge-available: #2f4737;
				--badge-under-offer: #8b5a2b;
				--badge-sold: #6b6660;
			}
			* {
				box-sizing: border-box;
			}
			body {
				margin: 0;
				color: var(--fg);
				background: var(--bg);
				font-family:
					ui-sans-serif,
					system-ui,
					-apple-system,
					"Hiragino Sans",
					"Yu Gothic",
					sans-serif;
				-webkit-font-smoothing: antialiased;
				font-feature-settings: "ss01" on;
			}
			h1,
			h2,
			h3 {
				font-family:
					ui-serif,
					"Iowan Old Style",
					"Hiragino Mincho ProN",
					Georgia,
					serif;
				font-weight: 600;
				letter-spacing: -0.018em;
			}
			a {
				color: inherit;
			}
			.shell {
				max-width: 76rem;
				margin: 0 auto;
				padding: 0 clamp(1rem, 4vw, 3rem);
			}
			.site-header {
				position: sticky;
				top: 0;
				z-index: 30;
				background: var(--header-bg);
				border-bottom: 1px solid var(--line);
				backdrop-filter: saturate(140%) blur(8px);
			}
			.site-nav {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0.95rem 0;
				gap: 2rem;
			}
			.brand {
				display: inline-flex;
				align-items: baseline;
				gap: 0.55rem;
				text-decoration: none;
			}
			.brand .mark {
				font-family:
					ui-serif,
					"Iowan Old Style",
					Georgia,
					serif;
				font-size: 1.55rem;
				font-weight: 700;
				letter-spacing: -0.035em;
				line-height: 1;
				color: var(--fg);
			}
			.brand .dot {
				display: inline-block;
				width: 5px;
				height: 5px;
				border-radius: 50%;
				background: var(--accent);
				transform: translateY(-0.3rem);
			}
			.brand .sub {
				font-family:
					ui-sans-serif,
					system-ui,
					sans-serif;
				font-size: 0.78rem;
				color: var(--muted);
				text-transform: uppercase;
				letter-spacing: 0.18em;
				font-weight: 500;
				transform: translateY(-0.1rem);
			}
			@media (max-width: 480px) {
				.brand .sub {
					font-size: 0.7rem;
					letter-spacing: 0.14em;
				}
			}
			.nav-links {
				display: flex;
				align-items: center;
				gap: 2rem;
				font-size: 0.93rem;
			}
			.nav-links a {
				color: var(--muted);
				text-decoration: none;
				position: relative;
				padding: 0.25rem 0;
				transition: color 0.15s;
			}
			.nav-links a:hover,
			.nav-links a:focus-visible {
				color: var(--fg);
				outline: none;
			}
			.nav-links a[aria-current="page"] {
				color: var(--fg);
			}
			.nav-links a[aria-current="page"]::after {
				content: "";
				position: absolute;
				left: 0;
				right: 0;
				bottom: -0.55rem;
				height: 2px;
				background: var(--accent);
				border-radius: 2px;
			}
			footer {
				margin-top: 8rem;
				padding: 6rem 0 5rem;
				border-top: 1px solid var(--line);
				color: var(--muted);
				font-size: 0.95rem;
				line-height: 1.7;
			}
			footer a {
				color: var(--accent);
				text-decoration: underline;
				text-underline-offset: 3px;
			}
			footer a:hover {
				filter: brightness(1.2);
			}
			.foot-pitch {
				max-width: 46rem;
				margin: 0 auto 4.5rem;
				text-align: center;
			}
			.foot-pitch p {
				margin: 0 0 1.25rem;
			}
			.foot-pitch p:last-child {
				margin-bottom: 0;
			}
			.foot-h {
				font-family: ui-serif, "Iowan Old Style", Georgia, serif;
				font-size: 1.45rem;
				color: var(--fg);
				font-weight: 600;
				margin-bottom: 1.5rem !important;
				line-height: 1.35;
			}
			.foot-cta-wrap {
				margin-top: 2rem !important;
			}
			.foot-cta {
				display: inline-block;
				padding: 0.7rem 1.4rem;
				background: var(--accent);
				color: var(--card) !important;
				border-radius: 8px;
				font-weight: 500;
				text-decoration: none !important;
				transition: filter 0.15s;
			}
			.foot-cta:hover {
				filter: brightness(1.15);
			}
			.foot-meta {
				padding-top: 2.5rem;
				border-top: 1px solid var(--line);
				display: flex;
				flex-wrap: wrap;
				justify-content: space-between;
				align-items: baseline;
				gap: 1.5rem;
				font-size: 0.82rem;
				color: var(--faint);
				line-height: 1.65;
			}
			.foot-disclaim {
				margin: 0;
				flex: 1 1 24rem;
				max-width: 48rem;
			}
			.foot-disclaim strong {
				color: var(--muted);
				font-weight: 600;
			}
			.foot-source {
				margin: 0;
				white-space: nowrap;
			}
			@media (max-width: 720px) {
				footer {
					padding: 4.5rem 0 3.5rem;
				}
				.foot-pitch {
					margin-bottom: 3.5rem;
				}
			}
			@media (max-width: 480px) {
				.nav-links {
					gap: 1.25rem;
					font-size: 0.88rem;
				}
				.brand .mark {
					font-size: 1.35rem;
				}
			}
		</style>
	</head>
	<body>
		<header class="site-header">
			<div class="shell">
				<div class="site-nav">
					<a class="brand" href="/">
						<span class="mark">Inaka</span><span class="dot"></span><span class="sub">Properties</span>
					</a>
					<nav class="nav-links">
						<a href="/" aria-current={path === "/" ? "page" : undefined}>Listings</a>
						<a href="/map" aria-current={path === "/map" ? "page" : undefined}>Map</a>
						<a href="https://github.com/kuracms/kura-property-website-example" rel="noreferrer">Source</a>
					</nav>
				</div>
			</div>
		</header>
		<main class={fullBleed ? "" : "shell"}>
			<slot />
		</main>
		{!fullBleed && (
			<footer>
				<div class="shell foot-shell">
					<div class="foot-pitch">
						<p class="foot-h">A demo site, powered by <a href="https://kuracms.com">kura</a>.</p>
						<p>
							This page is a working example of a small property frontend
							backed by <a href="https://kuracms.com">kura</a>, a hosted content
							backend. Your clients edit their own listings - words, photos,
							prices, status - through a clean admin interface. You build
							whatever frontend you like against the public API. No bespoke CMS
							to build, nothing to lose customer data over.
						</p>
						<p class="foot-cta-wrap">
							<a class="foot-cta" href="https://kuracms.com">See what kura can do</a>
						</p>
					</div>
					<div class="foot-meta">
						<p class="foot-disclaim">
							<strong>The listings on this site are fictitious.</strong>
							Photos and locations are representative; descriptions, prices and
							stories about previous owners are invented for the purposes of
							this demo. Nothing here is for sale.
						</p>
						<p class="foot-source">
							Source on
							<a href="https://github.com/kuracms/kura-property-website-example">GitHub</a>.
						</p>
					</div>
				</div>
			</footer>
		)}
	</body>
</html>
